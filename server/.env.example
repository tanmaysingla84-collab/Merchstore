# ─── Server ───────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── Database ─────────────────────────────────────────────

MONGO_URI=mongodb+srv://SubhamN:SubhamN123@cluster0.rzdj4tl.mongodb.net/

# ─── Auth (M1) ────────────────────────────────────────────
JWT_SECRET=<strong_random_secret_min_32_chars>
JWT_EXPIRES_IN=7d
GOOGLE_CLIENT_ID=<from_google_console>
GOOGLE_CLIENT_SECRET=<from_google_console>
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# ─── Cloudinary (M1) ──────────────────────────────────────
CLOUDINARY_CLOUD_NAME=<cloud_name>
CLOUDINARY_API_KEY=<api_key>
CLOUDINARY_API_SECRET=<api_secret>

# ─── Stripe (M2) ──────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_<key>
STRIPE_WEBHOOK_SECRET=whsec_<key>

# ─── Email / SMTP (M2) ────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=merch@geetauniversity.ac.in
SMTP_PASS=<google_app_password>
ALERT_EMAIL=admin@geetauniversity.ac.in

# ─── Inventory Cron (M2) ──────────────────────────────────
LOW_STOCK_THRESHOLD=10
CRON_SCHEDULE="0 8 * * *"

# ─── Rate Limiting ────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
ORDER_RATE_LIMIT_MAX=10
ORDER_RATE_LIMIT_WINDOW_MS=60000

# ─── Client URL ───────────────────────────────────────────
CLIENT_URL=http://localhost:5173
